{
  "name": "brigada-auto-testing",
  "version": "0.1.0",
  "private": true,
  "description": "Esqueleto de pruebas automatizadas con Playwright para Brigada",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:frontend": "playwright test --config=playwright.frontend.config.ts",
    "test:e2e:frontend:headed": "playwright test --config=playwright.frontend.config.ts --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "install:browsers": "playwright install"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@playwright/test": "^1.53.2",
    "dotenv": "^16.4.5"
  }
}

    {
      "name": "🔧 Setup — Admin Login & Discover IDs",
      "item": [
        {
          "name": "Admin Login",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Admin login 200', () => pm.response.to.have.status(200));",
            "const t = pm.response.json().access_token;",
            "pm.expect(t, 'access_token present').to.be.a('string');",
            "pm.collectionVariables.set('admin_token', t);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [],
            "body": { "mode": "urlencoded", "urlencoded": [
              { "key": "username", "value": "{{admin_email}}", "type": "text" },
              { "key": "password", "value": "{{admin_password}}", "type": "text" }
            ]},
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth","login"] }
          }
        },
        {
          "name": "Discover: QA Surveys",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Surveys list 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "const items = Array.isArray(json) ? json : (json.items || json.data || []);",
            "const qa = items.filter(s => s.title && s.title.startsWith('QA'));",
            "pm.test('At least 2 QA surveys exist', () => pm.expect(qa.length).to.be.at.least(2));",
            "if (qa.length >= 1) pm.collectionVariables.set('survey_id_in_scope', String(qa[0].id));",
            "if (qa.length >= 3) pm.collectionVariables.set('survey_id_out_scope', String(qa[2].id));",
            "const firstVersion = qa[0] && (qa[0].current_version_id || (qa[0].versions && qa[0].versions[0] && qa[0].versions[0].id));",
            "if (firstVersion) pm.collectionVariables.set('survey_version_id', String(firstVersion));",
            "console.log('in_scope=', pm.collectionVariables.get('survey_id_in_scope'),",
            "           'out_scope=', pm.collectionVariables.get('survey_id_out_scope'));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/admin/surveys/metadata?limit=50", "host": ["{{base_url}}"], "path": ["admin","surveys","metadata"], "query": [{ "key": "limit", "value": "50" }] }
          }
        },
        {
          "name": "Discover: Users (alpha/beta/admin)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Users list 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "const users = Array.isArray(json) ? json : (json.items || json.data || []);",
            "for (const u of users) {",
            "  if (u.email === 'qa.brigadista.alpha@qa.brigada.com') pm.collectionVariables.set('user_id_brig_alpha', String(u.id));",
            "  if (u.email === 'qa.encargado.alpha@qa.brigada.com')  pm.collectionVariables.set('user_id_enc_alpha',  String(u.id));",
            "  if (u.email === pm.collectionVariables.get('admin_email')) pm.collectionVariables.set('user_id_admin', String(u.id));",
            "}",
            "console.log('brig_alpha=', pm.collectionVariables.get('user_id_brig_alpha'),",
            "            'enc_alpha=',  pm.collectionVariables.get('user_id_enc_alpha'),",
            "            'admin=',      pm.collectionVariables.get('user_id_admin'));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/users?limit=100", "host": ["{{base_url}}"], "path": ["users"], "query": [{ "key": "limit", "value": "100" }] }
          }
        },
        {
          "name": "Discover: Role IDs (brigadista/encargado)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('Roles list 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "const roles = Array.isArray(json) ? json : (json.items || json.data || []);",
            "for (const r of roles) {",
            "  if (r.key === 'brigadista') pm.collectionVariables.set('role_id_brigadista', String(r.id));",
            "  if (r.key === 'encargado')  pm.collectionVariables.set('role_id_encargado',  String(r.id));",
            "}",
            "console.log('brigadista=', pm.collectionVariables.get('role_id_brigadista'),",
            "            'encargado=',  pm.collectionVariables.get('role_id_encargado'));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/roles", "host": ["{{base_url}}"], "path": ["roles"] }
          }
        }
      ]

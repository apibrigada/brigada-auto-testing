{
  "version": 2,
  "cases": [
    {
      "id": "match_true",
      "expression": {
        "match": [
          {
            "var": "answers.code"
          },
          "^AB[0-9]{2}$"
        ]
      },
      "data": {
        "answers": {
          "code": "AB12"
        }
      },
      "expected": true
    },
    {
      "id": "match_false",
      "expression": {
        "match": [
          {
            "var": "answers.code"
          },
          "^AB[0-9]{2}$"
        ]
      },
      "data": {
        "answers": {
          "code": "ZZ99"
        }
      },
      "expected": false
    },
    {
      "id": "date_diff_days",
      "expression": {
        "date_diff": [
          {
            "var": "answers.end"
          },
          {
            "var": "answers.start"
          },
          "days"
        ]
      },
      "data": {
        "answers": {
          "start": "2026-04-20",
          "end": "2026-04-23"
        }
      },
      "expected": 3
    },
    {
      "id": "count_array",
      "expression": {
        "count": [
          {
            "var": "answers.items"
          }
        ]
      },
      "data": {
        "answers": {
          "items": [
            "a",
            "b",
            "c"
          ]
        }
      },
      "expected": 3
    },
    {
      "id": "between_number_true",
      "expression": {
        "between": [
          {
            "var": "answers.score"
          },
          5,
          10
        ]
      },
      "data": {
        "answers": {
          "score": 7
        }
      },
      "expected": true
    },
    {
      "id": "geo_area_polygon",
      "expression": {
        "geo_area": [
          {
            "var": "answers.polygon"
          }
        ]
      },
      "data": {
        "answers": {
          "polygon": {
            "type": "Polygon",
            "coordinates": [
              [
                [
                  -99.1332,
                  19.4326
                ],
                [
                  -99.1332,
                  19.4336
                ],
                [
                  -99.1322,
                  19.4336
                ],
                [
                  -99.1322,
                  19.4326
                ],
                [
                  -99.1332,
                  19.4326
                ]
              ]
            ]
          }
        }
      }
    },
    {
      "id": "attachment_size_object",
      "expression": {
        "attachment_size": [
          {
            "var": "answers.photo"
          }
        ]
      },
      "data": {
        "answers": {
          "photo": {
            "storage_key": "r2/surveys/file.jpg",
            "size_bytes": 2048
          }
        }
      },
      "expected": 2048
    },
    {
      "id": "attachment_size_array_sum",
      "expression": {
        "attachment_size": [
          {
            "var": "answers.files"
          }
        ]
      },
      "data": {
        "answers": {
          "files": [
            {
              "size_bytes": 50
            },
            {
              "size": 75
            }
          ]
        }
      },
      "expected": 125
    },
    {
      "id": "forbidden_operator_rejected",
      "expression": {
        "eval": [
          "1+1"
        ]
      },
      "data": {
        "answers": {}
      },
      "expect_error": true,
      "error_contains": "forbidden operator"
    },

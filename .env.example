# URL de la app webCMS desplegada a probar
E2E_BASE_URL=https://web-cms-git-dev-brigadadigitals-projects.vercel.app/

# Credenciales para prueba de login (opcionales)
# Copia estas variables a tu archivo .env local y reemplaza los valores por los reales.

# Admin
E2E_LOGIN_EMAIL_ROLE_1=admin@brigada.com
E2E_LOGIN_PASSWORD_ROLE_1=contraseña123
E2E_NEW_IMG_URL_1=https://castelancarpinteyro.com/tux-guevara.png

# Encargado
E2E_LOGIN_EMAIL_ROLE_2=encargado@brigada.com
E2E_LOGIN_PASSWORD_ROLE_2=contraseña123

# Brigadista
E2E_LOGIN_EMAIL_ROLE_3=brigadista@brigada.com
E2E_LOGIN_PASSWORD_ROLE_3=contraseña123

# URL base del backend (requerida para los tests de permisos).
API_BASE_URL=http://localhost:8000

# ── QA Permission Tests ──────────────────────────────────────────────────────
# Contraseña compartida de todos los usuarios QA (seed_qa_permissions.py)
QA_USER_PASSWORD=QABrigada2026!

# Vars para Maestro mobile flows (SCEN-15 / SCEN-16)
TEST_ALPHA_EMAIL=qa.brigadista.alpha@qa.brigada.com
TEST_BETA_EMAIL=qa.brigadista.beta@qa.brigada.com
TEST_ENC_ALPHA_EMAIL=qa.encargado.alpha@qa.brigada.com
TEST_ENC_BETA_EMAIL=qa.encargado.beta@qa.brigada.com

# Solo aplica para ejecucion local con webServer interno
# Carpeta del proyecto webCMS (por defecto, repositorio hermano: ../webCMS)
E2E_WEB_SERVER_CWD=../webCMS

# Solo aplica para ejecucion local con webServer interno
# Comando para levantar webCMS antes de correr pruebas
E2E_WEB_SERVER_COMMAND=npm run dev -- --port 3100

# Para correr contra servidores desplegados, debe estar en true
E2E_DISABLE_WEBSERVER=true
